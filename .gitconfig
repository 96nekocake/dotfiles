[alias]
    br = branch
    cm = commit -m
    ch = checkout
    see = browse
    st = status
    gr = log --graph --date=short --decorate=short --pretty=format:'%Cgreen%h %Creset%cd %Cblue%cn %Cred%d %Creset%s'
    cl = "clone"
    brdel = git push origin --delete remoteBranchName

[include]
    path = .gitconfig.local
[core]
	excludesfile = /Users/narumi/.gitignore_global
[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /Applications/Sourcetree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
[user]
	name = akito.nakatani
	email = akito.nakatani1022@gmail.com
[commit]
	template = /Users/narumi/.stCommitMsg
